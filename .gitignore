# =============================================================================
# .gitignore — Aniyomi Extensions project (GitHub-hosted)
# =============================================================================

# ── Secrets / signing keys (NEVER commit) ──────────────────────────────────
*.jks
*.keystore
keystore-info.txt
*.p12
*.pem
skills/*.jks

# ── Android / Gradle build outputs ─────────────────────────────────────────
**/build/
**/.gradle/
**/local.properties
*.apk
*.aab
*.dex
*.class
*.iml

# ── Next.js / Node ─────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/coverage
/.next/
/out/
/build
.DS_Store
*.tsbuildinfo
next-env.d.ts

# ── Environment & logs ─────────────────────────────────────────────────────
.env*
!.env.example
*.log
dev.log
dev.out.log
server.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Editor / OS ────────────────────────────────────────────────────────────
.claude
.z-ai-config
local-*
.vscode/
.idea/
*.swp
*~

# ── Large reference material (regeneratable — see SHARED/README.md) ────────
SHARED/REFERENCE_HUB/
SHARED/APK_REFERENCE/

# ── Redundant backups & scratch dirs (do not push) ─────────────────────────
aniyomi-backup/
tool-results/
upload/
download/
test
prompt

# ── Sandbox-only skill definitions (Z.ai environment, not part of project) ─
skills/

# ── Sandbox scripts (contain tokens — never commit) ────────────────────────
.zscripts/

# ── Built APKs served via GitHub Releases (not committed) ──────────────────
public/apk/
